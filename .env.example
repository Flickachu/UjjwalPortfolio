# Example environment variables
# Public analytics (Google Analytics Measurement ID)
PUBLIC_GA_ID=G-XXXXXXXXXX

# Formspree or other form endpoint
FORMSPREE_URL=

# Sanity (if using) -- not required for the mini CMS
SANITY_PROJECT_ID=
SANITY_DATASET=production

# GitHub commit settings (for the built-in headless CMS)
GITHUB_TOKEN=
GITHUB_REPO=owner/repo
GITHUB_BRANCH=main
